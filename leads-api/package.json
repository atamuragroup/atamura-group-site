{
  "name": "atamura-leads-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Atamura Group — lead/site-form capture backend (JSONL + Bitrix24 + Telegram)",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build": "esbuild server/index.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist-server/server.mjs --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "start": "node dist-server/server.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "1.19.14",
    "decimal.js-light": "2.5.1",
    "hono": "4.12.23"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@vitest/coverage-v8": "3.2.6",
    "esbuild": "0.24.2",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "vitest": "3.2.6"
  }
}
