# ── Runtime ──
PORT=3000
HOST=0.0.0.0
LEADS_FILE=/app/data/leads.jsonl
SITE_LEADS_FILE=/app/data/site-leads.jsonl

# ── CORS allowlist (comma-separated) ──
# Own origins (apex + www) first; keep the calculator origin through migration.
# Same-origin POSTs from the site need no CORS, but list these so preflight /
# cross-subdomain callers still succeed. Never leave this as "*".
ALLOWED_ORIGIN=https://atamuragroup.kz,https://www.atamuragroup.kz,https://calculator.atamuragroup.kz

# ── Bitrix24 (optional mirror) ──
BITRIX_WEBHOOK_URL=
BITRIX_SOURCE_ID=WEB

# ── Telegram (optional mirror) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Admin leads viewer (optional — /api/leads is disabled when unset) ──
ADMIN_PASSWORD=
ADMIN_TOKEN_SECRET=
